{
  "name": "smart-receipt-processor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/api/src",
    "packages/database",
    "queue",
    "shared",
    "worker"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "start": "npm run start:api",
    "start:api": "node dist/apps/api/src/server.js",
    "start:worker": "node dist/worker/src/index.js",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:worker": "tsx watch worker/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^7.0.2"
  }
}
